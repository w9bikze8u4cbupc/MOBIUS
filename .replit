modules = ["nodejs-20", "python-3.12", "bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.development]
NODE_ENV = "development"
PORT = "5001"
MOBIUS_CORS_ORIGINS = "*"
DB_DATA_DIR = "./data"
DB_DATA_FILE = "./data/projects.json"
OUTPUT_DIR = "./output/MobiusGames"
JOB_RESULTS_DIR = "./src/api/uploads/render-jobs"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd client && PORT=5000 HOST=0.0.0.0 npm start"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80
