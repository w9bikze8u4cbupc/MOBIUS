modules = ["nodejs-20", "python-3.12", "bash"]
[agent]
expertMode = true
integrations = ["javascript_openai_ai_integrations:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["poppler"]

[userenv]

[userenv.development]
NODE_ENV = "development"
PORT = "5001"
MOBIUS_CORS_ORIGINS = "*"
DB_DATA_DIR = "./data"
DB_DATA_FILE = "./data/projects.json"
OUTPUT_DIR = "./output/MobiusGames"
JOB_RESULTS_DIR = "./src/api/uploads/render-jobs"

[userenv.production]
PORT = "5000"
HOST = "0.0.0.0"
NODE_ENV = "production"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd client && PORT=5000 HOST=0.0.0.0 npm start"
waitForPort = 5000

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8000 node src/api/index.js"
waitForPort = 8000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 32795
externalPort = 3002

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "NODE_ENV=production PORT=5000 node src/api/index.js"]
build = ["bash", "-c", "npm install && npm run build"]
