{
  "name": "mobius-games-tutorial-generator",
  "version": "1.0.1",
  "description": "A pipeline for generating game tutorial videos from structured game rules",
  "main": "index.js",
  "scripts": {
    "start": "NODE_ENV=production node src/api/index.js",
    "build": "cd client && npm run build",
    "dev": "node src/api/index.js",
    "postinstall": "cd client && npm install",
    "compile-shotlist": "node scripts/compile-shotlist.mjs",
    "bind-alignment": "node scripts/bind-alignment.mjs",
    "render": "node scripts/render-ffmpeg.mjs",
    "verify": "node scripts/verify.mjs",
    "test-pipeline": "npm run compile-shotlist && npm run verify && npm run bind-alignment",
    "test": "jest --testPathIgnorePatterns='/eliteVerifierSkeleton\\.test\\.mjs$'",
    "test:elite": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.elite.mjs",
    "gen:shotlists": "node scripts/compile-shotlist.mjs gigs/hanamikoji.json > tmp/shotlist.json",
    "gen:timelines": "echo 'Generating timelines...'",
    "render:proxy": "node scripts/render-ffmpeg.mjs tmp/timeline.json assets out/preview.mp4 --preview",
    "render:storyboard": "node scripts/render-storyboard-ffmpeg.mjs --config",
    "render:storyboard:smoke": "node scripts/render-storyboard-ffmpeg.mjs --config tests/fixtures/render/two-scene-config.json --out out/smoke-storyboard.mp4 --dry-run",
    "sync:captions-config": "node scripts/sync_captions_config.cjs",
    "golden:check": "npm run golden:check:sushi && npm run golden:check:loveletter",
    "golden:update:sushi": "node scripts/generate_golden.js --game \"Sushi Go\" --in \"out/sushi-go/preview.mp4\" --out \"tests/golden/sushi-go\" --frames \"5,10,20\"",
    "golden:update:loveletter": "node scripts/generate_golden.js --game \"Love Letter\" --in \"out/love-letter/preview.mp4\" --out \"tests/golden/love-letter\" --frames \"5,10,20\"",
    "golden:check:sushi": "node scripts/check_golden.js --game \"Sushi Go\" --in \"out/sushi-go/preview.mp4\" --golden \"tests/golden/sushi-go\" --frames \"5,10,20\" --ssim \"0.995\" --lufs_tol \"1.0\" --tp_tol \"1.0\"",
    "golden:check:loveletter": "node scripts/check_golden.js --game \"Love Letter\" --in \"out/love-letter/preview.mp4\" --golden \"tests/golden/love-letter\" --frames \"5,10,20\" --ssim \"0.995\" --lufs_tol \"1.0\" --tp_tol \"1.0\"",
    "golden:approve": "npm run golden:update:sushi && npm run golden:update:loveletter",
    "golden:check-with-junit": "node scripts/check_golden.js --game \"Hanamikoji\" --in \"out/preview.mp4\" --golden \"tests/golden/hanamikoji\" --frames \"5,10,20\" --ssim \"0.995\" --lufs_tol \"1.0\" --tp_tol \"1.0\" --junit tests/reports/hanamikoji.xml",
    "golden:update": "node scripts/generate_golden.js",
    "golden:check:junit": "node scripts/check_golden.js --junit tests/golden/reports/junit.xml",
    "golden:check:all": "node -e \"const {execSync}=require('child_process'); const games=['hanamikoji']; for(const g of games){ execSync('node scripts/check_golden.js --game \\\"'+g+'\\\" --in \\\"out/preview.mp4\\\" --perOs', {stdio:'inherit'}) }\"",
    "golden:snapshot:check": "node scripts/check_golden_snapshot.cjs --dir out/golden/sushi-go/windows/full-snapshot --junit out/junit/golden-snapshot-contract.junit.xml",
    "golden:snapshot:promote": "node scripts/promote_golden_snapshot.cjs --game sushi-go --os windows --mode full --snapshot out/golden/sushi-go/windows/full-snapshot --target tests/golden/sushi-go/windows --dry-run false --junit out/junit/golden-promotion-contract.junit.xml",
    "desktop:create": "node scripts/create-desktop-shortcut.mjs",
    "desktop:verify": "node scripts/verify-desktop-shortcuts.mjs",
    "ingestion:validate": "node scripts/check_ingestion.cjs",
    "storyboard:check": "node scripts/check_storyboard.cjs",
    "checklist:validate": "node scripts/validate_mobius_checklist.cjs",
    "mobius:e2e": "node scripts/run_mobius_e2e.cjs --game hanamikoji --lang en --resolution 1920x1080 --mode preview"
  },
  "keywords": [
    "game",
    "tutorial",
    "video",
    "generator",
    "rules"
  ],
  "author": "Mobius Games",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.8",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "fast-xml-parser": "^4.3.2",
    "fs-extra": "^11.2.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.104.0",
    "pako": "^2.1.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdf-to-img": "^5.0.0",
    "sharp": "^0.33.2",
    "tesseract.js": "^6.0.1",
    "typescript": "^5.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^18.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).[tj]s"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "eliteVerifierSkeleton\\.test\\.mjs$"
    ],
    "transform": {
      "^.+\\.m?[tj]s$": [
        "ts-jest",
        {
          "isolatedModules": true,
          "allowJs": true,
          "useESM": false,
          "tsconfig": {
            "esModuleInterop": true,
            "allowJs": true
          }
        }
      ]
    }
  }
}
